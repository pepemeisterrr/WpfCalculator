<Window x:Class="WpfCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" 
        Height="560" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F7F1F9">

    <Window.Resources>

        <!-- Базовый стиль кнопки -->
        <Style x:Key="CalcButton" TargetType="Button">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Цифровые кнопки (0-9 и ,) -->
        <Style x:Key="NumberButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0E8F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Кнопки C, ±, % -->
        <Style x:Key="FunctionButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
            <Setter Property="Background" Value="#D8CCDE"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CBB8D4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Кнопки операций (+ − × ÷) -->
        <Style x:Key="OperatorButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
            <Setter Property="Background" Value="#7B2B8F"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="28"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6B257D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Кнопка "=" -->
        <Style x:Key="EqualsButton" TargetType="Button" BasedOn="{StaticResource CalcButton}">
            <Setter Property="Background" Value="#7B2B8F"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="28"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6B257D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Дисплей с лёгкой границей -->
        <Border Grid.Row="0" Grid.ColumnSpan="4" 
        Background="#F7F1F9"
        BorderBrush="#CBB8D4"
        BorderThickness="1.5"
        CornerRadius="12"
        Margin="4,4,4,12">
            <TextBlock Text="{Binding Display}" 
               FontSize="48" 
               FontWeight="Light"
               Foreground="#1A1A1A"
               TextAlignment="Right"
               VerticalAlignment="Center"
               Margin="20,10"/>
        </Border>

        <!-- Ряд 1 -->
        <Button Grid.Row="1" Grid.Column="0" Content="C"     Command="{Binding ClearCommand}"   Style="{StaticResource FunctionButton}"/>
        <Button Grid.Row="1" Grid.Column="1" Content="±"     Command="{Binding SignCommand}"    Style="{StaticResource FunctionButton}"/>
        <Button Grid.Row="1" Grid.Column="2" Content="%"     Command="{Binding PercentCommand}" Style="{StaticResource FunctionButton}"/>
        <Button Grid.Row="1" Grid.Column="3" Content="÷"     Command="{Binding OperatorCommand}" CommandParameter="÷" Style="{StaticResource OperatorButton}"/>

        <!-- Ряд 2 -->
        <Button Grid.Row="2" Grid.Column="0" Content="7" Command="{Binding NumberCommand}" CommandParameter="7" Style="{StaticResource NumberButton}"/>
        <Button Grid.Row="2" Grid.Column="1" Content="8" Command="{Binding NumberCommand}" CommandParameter="8" Style="{StaticResource NumberButton}"/>
        <Button Grid.Row="2" Grid.Column="2" Content="9" Command="{Binding NumberCommand}" CommandParameter="9" Style="{StaticResource NumberButton}"/>
        <Button Grid.Row="2" Grid.Column="3" Content="×" Command="{Binding OperatorCommand}" CommandParameter="×" Style="{StaticResource OperatorButton}"/>

        <!-- Ряд 3 -->
        <Button Grid.Row="3" Grid.Column="0" Content="4" Command="{Binding NumberCommand}" CommandParameter="4" Style="{StaticResource NumberButton}"/>
        <Button Grid.Row="3" Grid.Column="1" Content="5" Command="{Binding NumberCommand}" CommandParameter="5" Style="{StaticResource NumberButton}"/>
        <Button Grid.Row="3" Grid.Column="2" Content="6" Command="{Binding NumberCommand}" CommandParameter="6" Style="{StaticResource NumberButton}"/>
        <Button Grid.Row="3" Grid.Column="3" Content="−" Command="{Binding OperatorCommand}" CommandParameter="−" Style="{StaticResource OperatorButton}"/>

        <!-- Ряд 4 -->
        <Button Grid.Row="4" Grid.Column="0" Content="1" Command="{Binding NumberCommand}" CommandParameter="1" Style="{StaticResource NumberButton}"/>
        <Button Grid.Row="4" Grid.Column="1" Content="2" Command="{Binding NumberCommand}" CommandParameter="2" Style="{StaticResource NumberButton}"/>
        <Button Grid.Row="4" Grid.Column="2" Content="3" Command="{Binding NumberCommand}" CommandParameter="3" Style="{StaticResource NumberButton}"/>
        <Button Grid.Row="4" Grid.Column="3" Content="+" Command="{Binding OperatorCommand}" CommandParameter="+" Style="{StaticResource OperatorButton}"/>

        <!-- Ряд 5: 0 (две колонки), запятая, равно -->
        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                Content="0" 
                Command="{Binding NumberCommand}" CommandParameter="0" 
                Style="{StaticResource NumberButton}"
                HorizontalContentAlignment="Left"
                Padding="28,0,0,0"/>

        <Button Grid.Row="5" Grid.Column="2" Content="," Command="{Binding DecimalCommand}" Style="{StaticResource NumberButton}"/>
        <Button Grid.Row="5" Grid.Column="3" Content="=" Command="{Binding EqualsCommand}"   Style="{StaticResource EqualsButton}"/>

    </Grid>
</Window>